@model List<PrototipoCompras.Models.OrdenCompra>

@{
    ViewData["Title"] = "Órdenes de Compra";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Órdenes de Compra</h2>
        <p class="text-muted mb-0">Solo las órdenes en estado Recibida actualizan inventario.</p>
    </div>
</div>

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        Lista de órdenes
    </div>
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Número</th>
                    <th>Producto</th>
                    <th>Proveedor</th>
                    <th>Cantidad</th>
                    <th>Estado</th>
                    <th>Fecha creación</th>
                    <th>Fecha recepción</th>
                    <th>Usuario recepción</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.NumeroOrden</td>
                            <td>@item.Producto</td>
                            <td>@item.Proveedor</td>
                            <td>@item.Cantidad</td>
                            <td>
                                @if (item.Estado == "Recibida")
                                {
                                    <span class="badge bg-success">Recibida</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Estado</span>
                                }
                            </td>
                            <td>@item.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(item.FechaRecepcion.HasValue? item.FechaRecepcion.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.UsuarioRecepcion) ? "-" : item.UsuarioRecepcion)</td>
                            <td>
                                @if (item.Estado != "Recibida")
                                {
                                    <form asp-action="MarcarRecibida" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            Marcar como recibida
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled>
                                        Ya recibida
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted">No hay órdenes registradas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>