<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrototipoCompras</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            background-color: #f8f9fa;
        }

        header.dg-header {
            background-color: #273F8F;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            padding: 20px 50px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            position: relative;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            margin-bottom: 20px;
        }

        .header-top .brand h1 {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            font-size: 36px;
            color: white;
            font-weight: bold;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }


        .logout-btn {
            background-color: #f0f0f0;
            color: #273F8F;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .logout-btn:hover {
            background-color: #e0e0e0;
        }

        nav.dg-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        nav.dg-nav a {
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 10px 18px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px; /* Espacio entre icono y texto */
        }

        nav.dg-nav a:hover {
            background: white;
            color: #273F8F;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        .main-content {
            flex: 1;
            padding-top: 30px;
        }

        footer {
            background: #111;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: auto;
        }
    </style>
</head>
<body>
    <header class="dg-header">
        <div class="header-top">
            <div class="brand">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <h1>Bienvenido, @User.Identity.Name</h1>
                }
                else
                {
                    <h1>GESTIÓN DE COMPRAS</h1>
                }
            </div>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                    <div class="header-actions">
                        <a href="/Account/Profile" class="btn btn-success" style="margin-right:10px;">Modificar usuario</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline; margin:0; padding:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="logout-btn">Cerrar sesión</button>
                        </form>
                    </div>
            }
        </div>
        <nav class="dg-nav">
            <a asp-controller="Solicitudes" asp-action="Create"><i class="fa-regular fa-file-lines"></i> Nueva Solicitud</a>
            <a asp-controller="Solicitudes" asp-action="BossPanel"><i class="fa-solid fa-user-tie"></i> Panel del Jefe</a>
            <a asp-controller="Proveedores" asp-action="CreateEval"><i class="fa-solid fa-star"></i> Evaluar Proveedor</a>
            <a asp-controller="Proveedores" asp-action="History"><i class="fa-solid fa-list-check"></i> Historial Evaluaciones</a>
            <a asp-controller="Historial" asp-action="Index"><i class="fa-solid fa-history"></i> Historial de Compras</a>
            <a asp-controller="Contratos" asp-action="Index"><i class="fa-solid fa-file-contract"></i> Control de Contratos</a>
            <a asp-controller="Ordenes" asp-action="Index"><i class="fa-solid fa-cart-shopping"></i> Órdenes de Compra</a>
        </nav>
    </header>

    <div class="container main-content">
        @RenderBody()
    </div>

    <footer>
        © @DateTime.Now.Year Gestión de compras. Todos los derechos reservados.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>