@model PrototipoCompras.Models.SolicitudCompra
@{
    ViewData["Title"] = "Registrar Solicitud";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nueva Solicitud · Gestión de Compras</title>
    <style>
        * { box-sizing: border-box; }
        
        body {
            background: white;
            font-family: Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background-color: #273F8F;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-title {
            margin: 0;
            color: black;
            font-size: 32px;
            font-weight: 700;
        }

        .header-nav {
            display: flex;
            gap: 12px;
        }

        .header-nav a {
            padding: 8px 16px;
            background-color: rgba(0,0,0,0.1);
            color: black;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s;
        }

        .header-nav a:hover {
            background-color: rgba(0,0,0,0.2);
        }

        .breadcrumb {
            color: black;
            font-size: 14px;
            margin: 0;
            display: none;
        }

        .breadcrumb a {
            color: black;
            text-decoration: none;
            margin-right: 5px;
        }

        .breadcrumb a:hover {
            text-decoration: underline;
        }

        main {
            flex: 1;
            padding: 40px 20px;
            max-width: 900px;
            margin: 0 auto;
            width: 100%;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-header h2 {
            margin: 0;
            color: #222;
            font-size: 32px;
            font-weight: 700;
        }

        .form-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
            font-size: 15px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            font-family: Arial, sans-serif;
            transition: all 0.3s;
            background: #fafafa;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            background: white;
            border-color: #273F8F;
            box-shadow: 0 0 0 3px rgba(154, 205, 50, 0.1);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-primary {
            background-color: #273F8F;
            color: white;
            box-shadow: 0 2px 8px rgba(39, 63, 143, 0.3);
        }

        .btn-primary:hover {
            background-color: #9acd32;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(154, 205, 50, 0.4);
        }

        .btn-secondary {
            background-color: #f0f0f0;
            color: #333;
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background-color: #e8e8e8;
        }

        .validation-summary {
            background-color: #ffebee;
            border-left: 4px solid #c62828;
            color: #b71c1c;
            padding: 12px 16px;
            border-radius: 6px;
            margin-bottom: 25px;
            font-size: 13px;
        }

        .validation-message {
            color: #c62828;
            font-size: 12px;
            margin-top: 5px;
        }

        footer {
            background-color: black;
            color: white;
            text-align: center;
            padding: 15px;
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-top: 40px;
        }

        @@media (max-width: 900px) {
            main {
                padding: 25px 15px;
            }
            .form-container {
                padding: 20px;
            }
            .page-header h2 {
                font-size: 26px;
            }
            header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            .header-nav {
                width: 100%;
                flex-wrap: wrap;
                gap: 8px;
            }
        }

        @@media (max-width: 600px) {
            main {
                padding: 15px 10px;
            }
            .form-container {
                padding: 15px;
            }
            .page-header h2 {
                font-size: 20px;
            }
            .form-actions {
                flex-direction: column;
                gap: 8px;
            }
            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>

    <main>
        <div class="page-header">
            <h2>📝 Registrar Solicitud de Compra</h2>
        </div>

        <div class="form-container">
            <form method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="validation-summary">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@e.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="form-group">
                    <label for="Fecha">Fecha *</label>
                    <input asp-for="Fecha" type="date" required />
                    <span asp-validation-for="Fecha" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Producto">Descripción del producto *</label>
                    <input asp-for="Producto" type="text" required placeholder="Describe el producto a solicitar" />
                    <span asp-validation-for="Producto" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Cantidad">Cantidad *</label>
                    <input asp-for="Cantidad" type="number" min="1" required />
                    <span asp-validation-for="Cantidad" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Justificacion">Justificación *</label>
                    <textarea asp-for="Justificacion" required placeholder="Justifica la solicitud de compra"></textarea>
                    <span asp-validation-for="Justificacion" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Solicitante">Solicitante</label>
                    <input asp-for="Solicitante" type="text" placeholder="EmpleadoDemo" />
                    <span asp-validation-for="Solicitante" class="validation-message"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Registrar</button>
                    <a href="/Solicitudes/BossPanel" class="btn btn-secondary">Ver Panel del Jefe</a>
                </div>
            </form>
        </div>
    </main>

</body>
</html>
