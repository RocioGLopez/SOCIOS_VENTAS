@model List<PrototipoCompras.Models.SolicitudCompra>
@{
    ViewData["Title"] = "Panel del Jefe";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Panel del Jefe · Gestión de Compras</title>
    <style>
        * { box-sizing: border-box; }
        
        body {
            background: white;
            font-family: Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background-color: #273F8F;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-title {
            margin: 0;
            color: black;
            font-size: 32px;
            font-weight: 700;
        }

        .header-nav {
            display: flex;
            gap: 12px;
        }

        .header-nav a {
            padding: 8px 16px;
            background-color: rgba(0,0,0,0.1);
            color: black;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s;
        }

        .header-nav a:hover {
            background-color: rgba(0,0,0,0.2);
        }

        main {
            flex: 1;
            padding: 40px 20px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-header h2 {
            margin: 0;
            color: #222;
            font-size: 32px;
            font-weight: 700;
        }

        .table-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th {
            background-color: #f5f5f5;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #e0e0e0;
        }

        table td {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        table tr:hover {
            background-color: #f9f9f9;
        }

        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-block;
            margin: 3px;
        }

        .btn-success {
            background-color: #4CAF50;
            color: white;
        }

        .btn-success:hover {
            background-color: #45a049;
        }

        .btn-danger {
            background-color: #f44336;
            color: white;
        }

        .btn-danger:hover {
            background-color: #da190b;
        }

        .btn-secondary {
            background-color: #f0f0f0;
            color: #333;
            border: 1px solid #ddd;
            margin-top: 20px;
            padding: 12px 24px;
        }

        .btn-secondary:hover {
            background-color: #e8e8e8;
        }

        footer {
            background-color: black;
            color: white;
            text-align: center;
            padding: 15px;
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-top: 40px;
        }

        @@media (max-width: 900px) {
            main {
                padding: 25px 15px;
            }
            .table-container {
                padding: 20px;
            }
            .page-header h2 {
                font-size: 26px;
            }
            header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            .header-nav {
                width: 100%;
                flex-wrap: wrap;
                gap: 8px;
            }
        }

        @@media (max-width: 600px) {
            main {
                padding: 15px 10px;
            }
            .table-container {
                padding: 15px;
            }
            .page-header h2 {
                font-size: 20px;
            }
            table th,
            table td {
                padding: 10px 5px;
                font-size: 12px;
            }
            .btn {
                padding: 6px 10px;
                font-size: 11px;
            }
        }
    </style>
</head>
<body>

    <main>
        <div class="page-header">
            <h2>👨‍💼 Panel del Jefe</h2>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Solicitante</th>
                        <th>Estado</th>
                        <th>Acciones (demo)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.Id</td>
                            <td>@s.Fecha.ToString("yyyy-MM-dd")</td>
                            <td>@s.Producto</td>
                            <td>@s.Cantidad</td>
                            <td>@s.Solicitante</td>
                            <td>@s.Estado</td>
                            <td>
                                <a class="btn btn-success" asp-action="Approve" asp-route-id="@s.Id">Aprobar</a>
                                <a class="btn btn-danger" asp-action="Reject" asp-route-id="@s.Id">Rechazar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <a href="/Solicitudes/Create" class="btn btn-secondary">Volver a crear solicitud</a>
    </main>

</body>
</html>