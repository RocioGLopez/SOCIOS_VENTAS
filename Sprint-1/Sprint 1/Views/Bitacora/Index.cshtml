@model IEnumerable<PrototipoCompras.Models.Bitacora>
@{
    ViewData["Title"] = "Bitácora de auditoría";
    var modulos = ViewBag.Modulos as List<string> ?? new List<string>();
}

<h2 class="mt-2 mb-4"><i class="fa-solid fa-clipboard-list"></i> Bitácora de auditoría</h2>
<p class="text-muted">Registro de acciones del sistema para facilitar la auditoría de transacciones y de la aplicación.</p>

<form method="get" class="row g-3 mb-4 p-3 bg-white rounded shadow-sm">
    <div class="col-md-3">
        <label class="form-label">Módulo</label>
        <select name="modulo" class="form-select">
            <option value="">Todos</option>
            @foreach (var m in modulos)
            {
                <option value="@m" selected="@(ViewBag.Modulo as string == m)">@m</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Usuario</label>
        <input type="text" name="usuario" class="form-control" value="@ViewBag.Usuario" placeholder="correo o nombre" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Desde</label>
        <input type="date" name="desde" class="form-control" value="@ViewBag.Desde" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Hasta</label>
        <input type="date" name="hasta" class="form-control" value="@ViewBag.Hasta" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" name="soloErrores" value="true" id="soloErrores"
                   @(ViewBag.SoloErrores == true ? "checked" : null) />
            <label class="form-check-label" for="soloErrores">Solo fallos</label>
        </div>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>Fecha (UTC)</th>
                <th>Usuario</th>
                <th>Módulo</th>
                <th>Acción</th>
                <th>Detalle</th>
                <th>Id ref.</th>
                <th>IP</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="8" class="text-center text-muted py-4">No hay registros con los filtros seleccionados.</td></tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Fecha.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.Usuario</td>
                    <td>@item.Modulo</td>
                    <td>@item.Accion</td>
                    <td class="small">@(item.Detalle ?? "—")</td>
                    <td>@(item.EntidadId?.ToString() ?? "—")</td>
                    <td class="small">@(item.IpAddress ?? "—")</td>
                    <td>
                        @if (item.Exitoso)
                        {
                            <span class="badge bg-success">OK</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Error</span>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
<p class="text-muted small mt-2">Se muestran como máximo los últimos 500 registros.</p>
