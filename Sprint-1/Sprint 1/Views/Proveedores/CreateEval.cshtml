@model PrototipoCompras.Models.EvaluacionProveedor
@{
    ViewData["Title"] = "Evaluar Proveedor";
    var proveedores = ViewBag.Proveedores as List<PrototipoCompras.Models.Proveedor>;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Evaluar Proveedor · Gestión de Compras</title>
    <style>
        * { box-sizing: border-box; }
        
        body {
            background: white;
            font-family: Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background-color: cyan;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-title {
            margin: 0;
            color: black;
            font-size: 32px;
            font-weight: 700;
        }

        .header-nav {
            display: flex;
            gap: 12px;
        }

        .header-nav a {
            padding: 8px 16px;
            background-color: rgba(0,0,0,0.1);
            color: black;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s;
        }

        .header-nav a:hover {
            background-color: rgba(0,0,0,0.2);
        }

        main {
            flex: 1;
            padding: 40px 20px;
            max-width: 900px;
            margin: 0 auto;
            width: 100%;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-header h2 {
            margin: 0;
            color: #222;
            font-size: 32px;
            font-weight: 700;
        }

        .form-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
            font-size: 15px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            font-family: Arial, sans-serif;
            transition: all 0.3s;
            background: #fafafa;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            background: white;
            border-color: cyan;
            box-shadow: 0 0 0 3px rgba(154, 205, 50, 0.1);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-primary {
            background-color: cyan;
            color: black;
            box-shadow: 0 2px 8px rgba(154, 205, 50, 0.3);
        }

        .btn-primary:hover {
            background-color: #9acd32;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(154, 205, 50, 0.4);
        }

        .btn-secondary {
            background-color: #f0f0f0;
            color: #333;
            border: 1px solid #ddd;
        }

        .btn-secondary:hover {
            background-color: #e8e8e8;
        }

        .validation-message {
            color: #c62828;
            font-size: 12px;
            margin-top: 5px;
        }

        footer {
            background-color: black;
            color: white;
            text-align: center;
            padding: 15px;
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-top: 40px;
        }

        @@media (max-width: 900px) {
            main {
                padding: 25px 15px;
            }
            .form-container {
                padding: 20px;
            }
            .page-header h2 {
                font-size: 26px;
            }
            header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            .header-nav {
                width: 100%;
                flex-wrap: wrap;
            }
        }

        @@media (max-width: 600px) {
            main {
                padding: 15px 10px;
            }
            .form-container {
                padding: 15px;
            }
            .page-header h2 {
                font-size: 20px;
            }
            .form-actions {
                flex-direction: column;
                gap: 8px;
            }
            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>

    <main>
        <div class="page-header">
            <h2>Historia #2 - Evaluación de Proveedores</h2>
        </div>

        <div class="form-container">
            <form method="post">
                <div class="form-group">
                    <label for="ProveedorId">Proveedor *</label>
                    <select asp-for="ProveedorId" required>
                        <option value="">Seleccione...</option>
                        @foreach (var p in proveedores!)
                        {
                            <option value="@p.Id">@p.Nombre</option>
                        }
                    </select>
                    <span asp-validation-for="ProveedorId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Score">Calificación (1 a 5) *</label>
                    <input asp-for="Score" type="number" min="1" max="5" required />
                    <span asp-validation-for="Score" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Comentario">Comentarios</label>
                    <textarea asp-for="Comentario" placeholder="Agregue sus comentarios sobre el proveedor"></textarea>
                    <span asp-validation-for="Comentario" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label for="Evaluador">Usuario evaluador</label>
                    <input asp-for="Evaluador" type="text" placeholder="ComprasDemo" />
                    <span asp-validation-for="Evaluador" class="validation-message"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Guardar evaluación</button>
                    <a href="/Proveedores/History" class="btn btn-secondary">Ver historial</a>
                </div>
            </form>
        </div>
    </main>

    <footer>
        &copy; 2026 Gestion de compras. Todos los derechos reservados.
    </footer>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>