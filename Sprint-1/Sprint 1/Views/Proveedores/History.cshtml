@model List<PrototipoCompras.Models.EvaluacionProveedor>
@{
    ViewData["Title"] = "Historial Evaluaciones";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Historial Evaluaciones · Gestión de Compras</title>
    <style>
        * { box-sizing: border-box; }
        
        body {
            background: white;
            font-family: Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background-color: #273F8F;
            color: white;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-title {
            margin: 0;
            color: black;
            font-size: 32px;
            font-weight: 700;
        }

        .header-nav {
            display: flex;
            gap: 12px;
        }

        .header-nav a {
            padding: 8px 16px;
            background-color: rgba(0,0,0,0.1);
            color: black;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s;
        }

        .header-nav a:hover {
            background-color: rgba(0,0,0,0.2);
        }

        main {
            flex: 1;
            padding: 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-header h2 {
            margin: 0;
            color: #222;
            font-size: 32px;
            font-weight: 700;
        }

        .table-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th {
            background-color: #f5f5f5;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #e0e0e0;
        }

        table td {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        table tr:hover {
            background-color: #f9f9f9;
        }

        .time-info {
            color: #666;
            font-size: 14px;
            margin-bottom: 20px;
            padding: 12px 16px;
            background-color: #f0f0f0;
            border-radius: 6px;
            border-left: 3px solid cyan;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-block;
            margin-top: 20px;
        }

        .btn-primary {
            background-color: #273F8F;
            color: white;
            box-shadow: 0 2px 8px rgba(154, 205, 50, 0.3);
        }

        .btn-primary:hover {
            background-color: #9acd32;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(154, 205, 50, 0.4);
        }

        footer {
            background-color: black;
            color: white;
            text-align: center;
            padding: 15px;
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            margin-top: 40px;
        }

        @@media (max-width: 900px) {
            main {
                padding: 25px 15px;
            }
            .table-container {
                padding: 20px;
            }
            .page-header h2 {
                font-size: 26px;
            }
            header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            .header-nav {
                width: 100%;
                flex-wrap: wrap;
                gap: 8px;
            }
        }

        @@media (max-width: 600px) {
            main {
                padding: 15px 10px;
            }
            .table-container {
                padding: 15px;
            }
            .page-header h2 {
                font-size: 20px;
            }
            table th,
            table td {
                padding: 10px 5px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>

    <main>
        <div class="page-header">
            <h2>📋 Historial de Evaluaciones</h2>
        </div>

        @if (ViewBag.TiempoMs != null)
        {
            <div class="time-info">
                <b>Tiempo de guardado:</b> @ViewBag.TiempoMs ms (meta ≤ 2000 ms)
            </div>
        }

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Proveedor</th>
                        <th>Score</th>
                        <th>Fecha</th>
                        <th>Evaluador</th>
                        <th>Comentario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@(e.Proveedor?.Nombre ?? "N/A")</td>
                            <td>@e.Score / 5</td>
                            <td>@e.Fecha.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@e.Evaluador</td>
                            <td>@e.Comentario</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <a href="/Proveedores/CreateEval" class="btn btn-primary">Registrar otra evaluación</a>
    </main>

</body>
</html>